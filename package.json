{
  "name": "scholaxis",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Korean-first research exploration engine with unified live-source ingestion, deduplication, and vector search.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "node --watch src/server.mjs",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 NODE_ENV=test node --test --test-concurrency=1 tests/api.test.mjs tests/search-quality-browser.test.mjs tests/search-quality-harness.test.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "smoke": "NODE_OPTIONS=--max-old-space-size=8192 NODE_ENV=test node scripts/smoke-test.mjs",
    "sync": "node scripts/sync-sources.mjs",
    "scheduler": "node scripts/start-scheduler.mjs",
    "worker": "node scripts/start-worker.mjs",
    "migrate:postgres": "node scripts/postgres-migrate.mjs",
    "validate:postgres": "node scripts/postgres-migrate.mjs --check",
    "translation-service": "node scripts/start-translation-service.mjs",
    "reranker-service": "node scripts/start-reranker-service.mjs",
    "vector-service": "node scripts/start-vector-service.mjs",
    "graph-service": "node scripts/start-graph-service.mjs",
    "quality:search": "node scripts/search-quality-browser.mjs",
    "backup": "node scripts/backup-sqlite.mjs",
    "restore": "node scripts/restore-sqlite.mjs",
    "verify": "npm run typecheck && npm run lint && npm test && npm run smoke",
    "local-model-service": "python3 scripts/local-model-server.py",
    "quality:search:quick": "SCHOLAXIS_QUALITY_API_RUNS=24 SCHOLAXIS_QUALITY_BROWSER_RUNS=6 SCHOLAXIS_QUALITY_LIVE_SAMPLE_RUNS=3 node scripts/search-quality-browser.mjs"
  },
  "license": "Apache-2.0"
}
