NODE_ENV=production
PORT=3000
APP_BASE_URL=https://research.example.com
API_BASE_URL=https://research.example.com
SESSION_SECRET=replace-with-a-long-random-secret
CONTENT_LOCALE=ko-KR
DEFAULT_SEARCH_REGION=KR
SEARCH_RATE_LIMIT_RPM=60
DETAIL_RATE_LIMIT_RPM=120
SIMILARITY_RATE_LIMIT_RPH=5
UPLOAD_MAX_MB=10
ENABLE_REPORT_SIMILARITY=true
CLOUDFLARE_TUNNEL_HOSTNAME=research.example.com

SCHOLAXIS_ENABLE_LIVE_SOURCES=false
SCHOLAXIS_AUTO_LIVE_ON_EMPTY=true
SCHOLAXIS_EXPERIMENTAL_LIVE_SOURCES=
# Quickstart/dev fallback:
SCHOLAXIS_STORAGE_BACKEND=sqlite
SCHOLAXIS_VECTOR_BACKEND=local
SCHOLAXIS_GRAPH_BACKEND=local
SCHOLAXIS_VECTOR_DIMS=1024
SCHOLAXIS_PORT_FALLBACK_ATTEMPTS=10
SCHOLAXIS_CITATION_EXPANSION_LIMIT=8
SCHOLAXIS_RECOMMENDATION_CANDIDATE_LIMIT=32
SCHOLAXIS_SOURCE_TIMEOUT_MS=4500
SCHOLAXIS_SOURCE_CACHE_TTL_MS=600000
SCHOLAXIS_MAX_LIVE_RESULTS_PER_SOURCE=8
SCHOLAXIS_MODEL_REQUEST_TIMEOUT_MS=20000
SCHOLAXIS_DB_PATH=.data/scholaxis.db
# Optional eager prewarm. Disabled by default to keep startup/health checks responsive.
# SCHOLAXIS_WARM_SEARCH_INDEX_ON_START=true

# Serious-use / recommended persistence path:
# SCHOLAXIS_STORAGE_BACKEND=postgres
# SCHOLAXIS_VECTOR_BACKEND=pgvector
# DATABASE_URL=postgres://scholaxis:password@127.0.0.1:5432/scholaxis
# npm run migrate:postgres -- --apply
# npm run validate:postgres

DATABASE_URL=
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=
PSQL_BIN=psql

SCHOLAXIS_EMBEDDING_PROVIDER=auto
SCHOLAXIS_EMBEDDING_SERVICE_URL=
SCHOLAXIS_EMBEDDING_MODEL=BAAI/bge-m3
SCHOLAXIS_EMBEDDING_API_KEY=
SCHOLAXIS_OLLAMA_URL=http://127.0.0.1:11434
SCHOLAXIS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
SCHOLAXIS_OLLAMA_RERANKER_MODEL=qwen2.5:3b
SCHOLAXIS_OLLAMA_QUERY_MODEL=qwen2.5:3b
SCHOLAXIS_OLLAMA_KEEP_ALIVE=5m

SCHOLAXIS_RERANKER_PROVIDER=auto
SCHOLAXIS_RERANKER_HOST=127.0.0.1
SCHOLAXIS_RERANKER_PORT=8300
SCHOLAXIS_RERANKER_AUTOSTART=true
SCHOLAXIS_RERANKER_STARTUP_TIMEOUT_MS=10000
SCHOLAXIS_RERANKER_SERVICE_URL=
SCHOLAXIS_RERANKER_API_KEY=
SCHOLAXIS_RERANKER_TOP_K=12
SCHOLAXIS_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
SCHOLAXIS_LOCAL_MODEL_PROVIDER=sentence-transformers
SCHOLAXIS_LOCAL_MODEL_HOST=127.0.0.1
SCHOLAXIS_LOCAL_MODEL_PORT=11435
SCHOLAXIS_LOCAL_MODEL_SERVICE_URL=http://127.0.0.1:11435
SCHOLAXIS_LOCAL_MODEL_AUTOSTART=true
SCHOLAXIS_LOCAL_MODEL_STARTUP_TIMEOUT_MS=180000
SCHOLAXIS_LOCAL_MODEL_PYTHON_BIN=python3
SCHOLAXIS_LOCAL_MODEL_DEVICE=cpu
SCHOLAXIS_LOCAL_MODEL_CACHE_DIR=

SCHOLAXIS_VECTOR_SERVICE_URL=
SCHOLAXIS_GRAPH_SERVICE_URL=
SCHOLAXIS_TRANSLATION_PROVIDER=generic
SCHOLAXIS_TRANSLATION_HOST=127.0.0.1
SCHOLAXIS_TRANSLATION_PORT=5001
SCHOLAXIS_TRANSLATION_AUTOSTART=true
SCHOLAXIS_TRANSLATION_STARTUP_TIMEOUT_MS=20000
SCHOLAXIS_TRANSLATION_SERVICE_URL=
SCHOLAXIS_TRANSLATION_API_KEY=
SCHOLAXIS_SCHEDULER_INTERVAL_MS=60000
SCHOLAXIS_WORKER_POLL_MS=1500
SCHOLAXIS_WORKER_LEASE_MS=15000

SEMANTIC_SCHOLAR_API_KEY=
DBPIA_API_KEY=
RISS_SEARCH_URL=https://www.riss.kr/search/Search.do
KIPRIS_PLUS_API_KEY=
KIPRIS_PLUS_SEARCH_URL=
KIPRIS_PUBLIC_SEARCH_URL=https://plus.kipris.or.kr/portal/search/clasList/List.do
KCI_SEARCH_URL=
NTIS_SEARCH_URL=https://www.ntis.go.kr/ThSearchProjectList.do
SCIENCEON_SEARCH_URL=https://scienceon.kisti.re.kr/srch/selectPORSrchArticleList.do
SCIENCE_FAIR_URL=https://www.science.go.kr/mps/1079/bbs/423/moveBbsNttList.do
STUDENT_INVENTION_FAIR_URL=https://www.science.go.kr/mps/1075/bbs/424/moveBbsNttList.do
RNE_REPORT_URL=http://www.rne.or.kr/gnuboard5/bbs/board.php?bo_table=rs_report
